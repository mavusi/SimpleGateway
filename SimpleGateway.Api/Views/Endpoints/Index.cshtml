@model IEnumerable<SimpleGateway.Api.Models.GatewayEndpoint>
<h2>Endpoints</h2>
<p><a href="/Endpoints/Create">Create New Endpoint</a></p>
<table>
    <thead>
        <tr>
            <th>Service</th>
            <th>Method</th>
            <th>Path</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach(var e in Model) {
    <tr>
        <td>@(e.Service?.Name ?? e.ServiceId)</td>
        <td>@e.Method</td>
        <td>@e.Path</td>
        <td>
            <a href="/Endpoints/Details/@e.Id">Details</a> |
            <a href="/Endpoints/Edit/@e.Id">Edit</a> |
            <a href="/Endpoints/Delete/@e.Id">Delete</a>
        </td>
    </tr>
}
    </tbody>
</table>
