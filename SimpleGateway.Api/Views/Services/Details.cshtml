@model SimpleGateway.Api.Models.GatewayService
<h2>Service Details</h2>
<div>
    <strong>Name:</strong> @Model.Name
</div>
<div>
    <strong>Url:</strong> @Model.Url
</div>
<div>
    <strong>Path:</strong> @Model.Path
</div>
<h3>Endpoints</h3>
<p><a href="/Endpoints/Create?serviceId=@Model.Id">Create Endpoint for this Service</a></p>
<table>
    <thead>
        <tr><th>Method</th><th>Path</th><th></th></tr>
    </thead>
    <tbody>
@foreach(var e in Model.Endpoints) {
    <tr>
        <td>@e.Method</td>
        <td>@e.Path</td>
        <td>
            <a href="/Endpoints/Details/@e.Id">Details</a> |
            <a href="/Endpoints/Edit/@e.Id">Edit</a> |
            <a href="/Endpoints/Delete/@e.Id">Delete</a>
        </td>
    </tr>
}
    </tbody>
</table>
<p><a href="/Services">Back to list</a></p>
