@model IEnumerable<SimpleGateway.Api.Models.GatewayService>
<h2>Services</h2>
<p><a href="/Services/Create">Create New Service</a></p>
<table>
    <thead>
        <tr>
            <th>Name</th>
            <th>Url</th>
            <th>Path</th>
            <th>Endpoints</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach(var s in Model) {
    <tr>
        <td>@s.Name</td>
        <td>@s.Url</td>
        <td>@s.Path</td>
        <td>@(s.Endpoints?.Count ?? 0)</td>
        <td>
            <a href="/Services/Details/@s.Id">Details</a> |
            <a href="/Services/Edit/@s.Id">Edit</a> |
            <a href="/Services/Delete/@s.Id">Delete</a>
        </td>
    </tr>
}
    </tbody>
</table>
